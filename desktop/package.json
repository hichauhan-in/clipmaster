{
  "name": "clipmaster-desktop",
  "version": "0.1.0",
  "description": "ClipMaster desktop editor — dark, minimal UI over the local ClipMaster pipeline.",
  "author": "ClipMaster",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-vite build && electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.clipmaster.desktop",
    "productName": "ClipMaster",
    "files": ["out/**/*"],
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"]
    }
  }
}
